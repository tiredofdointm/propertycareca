# Postgres connection string. Locally: docker compose up -d db
DATABASE_URL=postgresql://propertycare:propertycare@localhost:5432/propertycare

# Session secret used to sign the admin login cookie. Generate with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Admin login credentials (MVP single-admin auth). Generate a hash with:
#   npm run admin:hash-password -- 'your-password'
# IMPORTANT: escape every "$" as "\$" below — Next.js expands unescaped
# $vars in .env files, which silently corrupts bcrypt hashes.
ADMIN_EMAIL=admin@propertycareca.com
ADMIN_PASSWORD_HASH=

# "Sign in with Google" for the admin dashboard (optional). Create a Web
# OAuth client in Google Cloud Console — full walkthrough in
# docs/google-login-setup.md. ADMIN_EMAIL is always allowed; add extra
# allowed Google accounts as a comma-separated list.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADMIN_EMAILS=

# Stripe (test mode keys). Leave unset to disable deposit payments in dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public site URL, used to build Stripe redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (all optional — unset means no tracking scripts load at all).
# GA4 measurement id (G-XXXXXXX), and/or a GTM container id (GTM-XXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Google Ads conversion tracking. The conversion id is the "AW-XXXXXXX" from
# your Google Ads account; each label is the per-conversion-action label
# Google Ads gives you when you create a conversion action (Leads, Bookings,
# Deposits). Leave a label unset to skip firing that particular conversion.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
NEXT_PUBLIC_GOOGLE_ADS_LABEL_LEAD=
NEXT_PUBLIC_GOOGLE_ADS_LABEL_BOOKING=
NEXT_PUBLIC_GOOGLE_ADS_LABEL_DEPOSIT=
